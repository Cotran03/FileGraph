# Virtual environments
.venv/
venv/
ENV/

# Python cache and test artifacts
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
pytest_cache/
.coverage
coverage.xml
htmlcov/

# Runtime data
db/*.db
db/*.db-*
!db/template_db.db
logs/
*.log
config/settings.json
config/*.local.*
config/.env*
config/*secret*
config/*key*
!config/README.md

# Local QA and temp files
.filegraph-*
qa-localappdata*/
*.tmp

# Packaging outputs
build/
dist*/
# FileGraph.spec is intentionally not ignored; it is the PyInstaller build recipe.

# Local agent metadata
/.agents
